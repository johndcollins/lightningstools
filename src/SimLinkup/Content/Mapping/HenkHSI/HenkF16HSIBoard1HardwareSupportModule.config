<?xml version="1.0"?>
<Henk_F16_HSI_Board1 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Devices>
    <Device>
      <ConnectionType>USB</ConnectionType>
      <!-- can be either USB or PHCC -->
      <COMPort>COM4</COMPort>
      <Address>0x48</Address>
      <!-- HSI Board #1 firmware is given address 0x48, by default.  NOTE: This must match the actual DOA device address which is programmed into the firmware for this HSI card. -->

      <StatorOffsetsConfig>
        <HeadingS1Offset>600</HeadingS1Offset> <!-- 0 to 1024 -->
        <HeadingS2Offset>941</HeadingS2Offset> <!-- 0 to 1024 -->
        <HeadingS3Offset>258</HeadingS3Offset> <!-- 0 to 1024 -->
        <BearingS1Offset>89</BearingS1Offset> <!-- 0 to 1024 -->
        <BearingS2Offset>430</BearingS2Offset> <!-- 0 to 1024 -->
        <BearingS3Offset>771</BearingS3Offset> <!-- 0 to 1024 -->
        <RangeOnesDigitXOffset>682</RangeOnesDigitXOffset><!-- 0 to 1024 -->
        <RangeOnesDigitYOffset>853</RangeOnesDigitYOffset><!-- 0 to 1024 -->
        <RangeTensDigitXOffset>682</RangeTensDigitXOffset><!-- 0 to 1024 -->
        <RangeTensDigitYOffset>853</RangeTensDigitYOffset><!-- 0 to 1024 -->
        <RangeHundredsDigitXOffset>682</RangeHundredsDigitXOffset><!-- 0 to 1024 -->
        <RangeHundredsDigitYOffset>853</RangeHundredsDigitYOffset><!-- 0 to 1024 -->
      </StatorOffsetsConfig>
      
      <OutputChannelsConfig>
        <DIG_OUT_1>
          <InitialValue>false</InitialValue>
        </DIG_OUT_1>
        <DIG_OUT_2>
          <InitialValue>false</InitialValue>
        </DIG_OUT_2>
      </OutputChannelsConfig>
      
      
      <DiagnosticLEDMode>Heartbeat</DiagnosticLEDMode>
      
      <HeadingCalibrationData>
        <CalibrationPoint>
          <Input>0</Input>
          <Output>0</Output>
        </CalibrationPoint>
        <CalibrationPoint>
          <Input>360</Input>
          <Output>1023</Output>
        </CalibrationPoint>
      </HeadingCalibrationData>

      <BearingCalibrationData>
        <CalibrationPoint>
          <Input>0</Input>
          <Output>0</Output>
        </CalibrationPoint>
        <CalibrationPoint>
          <Input>360</Input>
          <Output>1023</Output>
        </CalibrationPoint>
      </BearingCalibrationData>

      <RangeOnesDigitCalibrationData>
        <CalibrationPoint>
          <Input>0</Input>
          <Output>0</Output>
        </CalibrationPoint>
        <CalibrationPoint>
          <Input>10</Input>
          <Output>1023</Output>
        </CalibrationPoint>
      </RangeOnesDigitCalibrationData>

      <RangeTensDigitCalibrationData>
        <CalibrationPoint>
          <Input>0</Input>
          <Output>0</Output>
        </CalibrationPoint>
        <CalibrationPoint>
          <Input>10</Input>
          <Output>1023</Output>
        </CalibrationPoint>
      </RangeTensDigitCalibrationData>

      <RangeHundredsDigitCalibrationData>
        <CalibrationPoint>
          <Input>0</Input>
          <Output>0</Output>
        </CalibrationPoint>
        <CalibrationPoint>
          <Input>10</Input>
          <Output>1023</Output>
        </CalibrationPoint>
      </RangeHundredsDigitCalibrationData>
      
    </Device>
  </Devices>
</Henk_F16_HSI_Board1>